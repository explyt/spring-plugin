<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <implicitUsageProvider implementation="com.esprito.spring.data.providers.SpringDataImplicitUsageProvider"/>
        <multiHostInjector
                implementation="com.esprito.spring.data.langinjection.JpqlSpringDataQueryLanguageInjector"/>
        <completion.contributor language="UAST"
                                implementationClass="com.esprito.spring.data.completion.SpringDataBaseCompletionContributor"
                                order="before javaMemberName"/>
    </extensions>

    <extensions defaultExtensionNs="com.esprito">
        <jpa.ql.reference.inputParameterReferenceResolver
                implementation="com.esprito.spring.data.reference.RepositoryQueryInputParameterReferenceResolver"/>
    </extensions>

    <extensions defaultExtensionNs="com.esprito.spring.core">
        <staticBeansDiscoverer
                implementation="com.esprito.spring.data.service.beans.discoverer.SpringDataStaticBeansDiscoverer"/>
    </extensions>

    <actions>

    </actions>
</idea-plugin>