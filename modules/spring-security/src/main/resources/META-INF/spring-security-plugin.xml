<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">

        <localInspection language="UAST"
                         shortName="SpringSecurityAnnotationWithUserDetailsInspection"
                         groupBundle="messages.SpringSecurityBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.security.notifications"
                         bundle="messages.SpringSecurityBundle"
                         key="esprito.spring.security.inspection.bean"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.security.inspections.SpringSecurityAnnotationWithUserDetailsInspection"/>

        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.security.references.contributors.SpringSecurityContributor"/>

    </extensions>

    <actions>

    </actions>
</idea-plugin>