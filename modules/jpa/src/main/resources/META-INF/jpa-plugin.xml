<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>


    <extensionPoints>
        <extensionPoint
                qualifiedName="com.esprito.jpa.ql.reference.inputParameterReferenceResolver"
                interface="com.esprito.jpa.ql.reference.InputParameterReferenceResolver"
                area="IDEA_PROJECT"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="JPA QL"
                implementationClass="com.esprito.jpa.ql.JpqlFileType"
                fieldName="INSTANCE"
                language="JPQL"
                extensions="jpql"/>

        <lang.parserDefinition
                language="JPQL"
                implementationClass="com.esprito.jpa.ql.psi.JpqlParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="JPQL"
                implementationClass="com.esprito.jpa.ql.highlight.JpqlSyntaxHighlighterFactory"/>

        <completion.contributor
                language="JPQL"
                implementationClass="com.esprito.jpa.ql.completion.JpqlCompletionContributor"/>

        <lang.braceMatcher
                language="JPQL"
                implementationClass="com.esprito.jpa.ql.psi.JpqlBraceMatcher"/>

        <multiHostInjector implementation="com.esprito.jpa.langinjection.JpqlEntityManagerLanguageInjector"/>
        <multiHostInjector implementation="com.esprito.jpa.langinjection.JpqNamedQueryLanguageInjector"/>

    </extensions>

    <actions>

    </actions>
</idea-plugin>