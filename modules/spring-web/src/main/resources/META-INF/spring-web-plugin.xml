<idea-plugin>

    <extensions defaultExtensionNs="com.esprito.spring.core">
        <additionalBeansDiscoverer
                implementation="com.esprito.spring.web.service.beans.discoverer.SpringWebAdditionalBeansDiscoverer"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastRequestMappingReferenceContributor"/>

        <implicitUsageProvider implementation="com.esprito.spring.web.providers.SpringWebImplicitUsageProvider"/>

        <completion.contributor language="UAST"
                                order="first"
                                implementationClass="com.esprito.spring.web.references.contributors.WebClientMethodCompletionContributor"/>

        <localInspection language="UAST"
                         shortName="SpringOmittedPathVariableParameterInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Esprito Spring Tool"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.pathVariable"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.web.inspections.SpringOmittedPathVariableParameterInspection"/>

        <localInspection language="UAST"
                         shortName="SpringInitBinderNonVoidInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Esprito Spring Tool"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.initBinder"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.SpringInitBinderNonVoidInspection"/>

        <localInspection language="UAST"
                         shortName="MockMvcTemplateParametersInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Esprito Spring Tool"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.mockMvc.parameters"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.MockMvcTemplateParametersInspection"/>

        <localInspection language="UAST"
                         shortName="WebClientTemplateParametersInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Esprito Spring Tool"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.webClient.parameters"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.WebClientUriParametersInspection"/>

        <localInspection language="UAST"
                         shortName="RequestMappingDuplicateInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Esprito Spring Tool"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.requestMapping.duplicate"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.RequestMappingDuplicateInspection"/>

        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.web.providers.ControllerEndpointLineMarkerProvider"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastMockMvcUrlReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastWebClientUrlReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.ControllerEndpointReturnReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.RedirectUrlReferenceContributor"/>

        <psi.referenceContributor language="yaml"
                                  implementation="com.esprito.spring.web.references.contributors.SpringOpenApiYamlUrlEndpointReferenceContributor"/>

        <psi.referenceContributor language="JSON"
                                  implementation="com.esprito.spring.web.references.contributors.SpringOpenApiJsonUrlEndpointReferenceContributor"/>

    </extensions>

    <actions>

    </actions>
</idea-plugin>