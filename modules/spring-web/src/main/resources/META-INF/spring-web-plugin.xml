<idea-plugin>

    <extensionPoints>
        <extensionPoint qualifiedName="com.esprito.spring.web.springWebEndpointsLoader" dynamic="true"
                        interface="com.esprito.spring.web.service.beans.discoverer.SpringWebEndpointsLoader"
                        area="IDEA_PROJECT"/>
    </extensionPoints>


    <extensions defaultExtensionNs="com.esprito.spring.web">
        <additionalBeansDiscoverer
                implementation="com.esprito.spring.web.service.beans.discoverer.SpringWebAdditionalBeansDiscoverer"/>

        <springWebEndpointsLoader
                implementation="com.esprito.spring.web.service.beans.discoverer.SpringWebControllerLoader"/>
        <springWebEndpointsLoader
                implementation="com.esprito.spring.web.service.beans.discoverer.SpringWebBeanEndpointsLoader"/>

    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastRequestMappingReferenceContributor"/>

        <implicitUsageProvider implementation="com.esprito.spring.web.providers.SpringWebImplicitUsageProvider"/>

        <completion.contributor language="UAST"
                                order="first"
                                implementationClass="com.esprito.spring.web.references.contributors.webClient.WebClientMethodCompletionContributor"/>

        <completion.contributor language="UAST"
                                order="first"
                                implementationClass="com.esprito.spring.web.references.contributors.webClient.WebTestClientMethodCompletionContributor"/>

        <completion.contributor language="yaml"
                                order="first"
                                implementationClass="com.esprito.spring.web.references.contributors.OpenApiYamlRefCompletionContributor"/>

        <completion.contributor language="JSON"
                                order="first"
                                implementationClass="com.esprito.spring.web.references.contributors.OpenApiJsonRefCompletionContributor"/>

        <localInspection language="UAST"
                         shortName="SpringOmittedPathVariableParameterInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.pathVariable"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.web.inspections.SpringOmittedPathVariableParameterInspection"/>

        <localInspection language="UAST"
                         shortName="SpringInitBinderNonVoidInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.initBinder"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.SpringInitBinderNonVoidInspection"/>

        <localInspection language="UAST"
                         shortName="MockMvcTemplateParametersInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.mockMvc.parameters"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.MockMvcTemplateParametersInspection"/>

        <localInspection language="UAST"
                         shortName="WebClientTemplateParametersInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.webClient.parameters"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.WebClientUriParametersInspection"/>

        <localInspection language="UAST"
                         shortName="RequestMappingDuplicateInspection"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.requestMapping.duplicate"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.web.inspections.RequestMappingDuplicateInspection"/>

        <localInspection language="UAST"
                         shortName="JavaWebClientMethodWrongType"
                         groupBundle="messages.SpringWebBundle"
                         groupPath="Spring Explyt"
                         groupKey="esprito.spring.web.notifications.core"
                         bundle="messages.SpringWebBundle"
                         key="esprito.spring.web.inspection.webClient.type"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.web.inspections.WebClientMethodWrongTypeInspection"/>

        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.web.providers.ControllerEndpointLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.web.providers.RouteFunctionEndpointLineMarkerProvider"/>

        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastMockMvcUrlReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.UastWebClientUrlReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.ControllerEndpointReturnReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.web.references.contributors.RedirectUrlReferenceContributor"/>

        <psi.referenceContributor language="yaml"
                                  implementation="com.esprito.spring.web.references.contributors.SpringOpenApiYamlUrlEndpointReferenceContributor"/>

        <psi.referenceContributor language="JSON"
                                  implementation="com.esprito.spring.web.references.contributors.SpringOpenApiJsonUrlEndpointReferenceContributor"/>

        <psi.referenceContributor language="yaml"
                                  implementation="com.esprito.spring.web.references.contributors.OpenApiYamlInnerReferenceContributor"/>

        <psi.referenceContributor language="JSON"
                                  implementation="com.esprito.spring.web.references.contributors.OpenApiJsonInnerReferenceContributor"/>

        <fileEditorProvider implementation="com.esprito.spring.web.editor.openapi.OpenApiUIEditorProvider"/>

        <httpRequestHandler implementation="com.esprito.spring.web.editor.openapi.OpenApiRequestHandler"/>
        <httpRequestHandler implementation="com.esprito.spring.web.editor.openapi.OpenApiProxyRequestHandler"/>

        <registryKey
                defaultValue="500000"
                description="Timeout (ms) for proxied request"
                key="openapi.ui.proxy.timeout"/>
        <registryKey
                defaultValue="true"
                description="Enable internal proxy for requests run from OpenAPI UI editor"
                key="openapi.ui.proxy.enable"/>

    </extensions>

    <projectListeners>
        <listener class="com.esprito.spring.web.listeners.EspritoWebProjectListener"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </projectListeners>


    <actions>

    </actions>
</idea-plugin>