<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.properties</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensionPoints>
        <extensionPoint qualifiedName="com.esprito.spring.core.configurationPropertiesLoader"
                        interface="com.esprito.spring.core.completion.properties.ConfigurationPropertiesLoader"
                        area="IDEA_PROJECT"/>

        <extensionPoint qualifiedName="com.esprito.spring.core.configurationFactoriesNamesLoader"
                        interface="com.esprito.spring.core.completion.properties.ConfigurationFactoriesNamesLoader"
                        area="IDEA_PROJECT"/>

        <extensionPoint qualifiedName="com.esprito.spring.core.profileSearcher"
                        interface="com.esprito.spring.core.profile.ProfileSearcher"
                        area="IDEA_PROJECT"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.esprito.spring.core">
        <configurationPropertiesLoader
                implementation="com.esprito.spring.core.completion.properties.SpringMetadataLibraryConfigurationPropertiesLoader"/>
        <configurationPropertiesLoader
                implementation="com.esprito.spring.core.completion.properties.ProjectConfigurationPropertiesLoader"/>
        <configurationFactoriesNamesLoader
                implementation="com.esprito.spring.core.completion.properties.AutoConfigurationImportsPropertiesLoader"/>
        <configurationFactoriesNamesLoader
                implementation="com.esprito.spring.core.completion.properties.SpringFactoriesConfigurationPropertiesLoader"/>

        <profileSearcher implementation="com.esprito.spring.core.profile.AnnotationProfileSearcher"/>
        <profileSearcher implementation="com.esprito.spring.core.profile.AdditionalProfileSearcher"/>
        <profileSearcher implementation="com.esprito.spring.core.profile.PropertyNameProfileSearcher"/>
        <profileSearcher implementation="com.esprito.spring.core.profile.MavenProfileSearcher"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="com.esprito.spring.notification"
                           displayType="BALLOON"
                           bundle="messages.SpringCoreBundle"
                           key="esprito.spring.common.notifications"/>

        <completion.contributor language="any"
                                id="com.esprito.spring.core.propertiesCompletionContributor"
                                implementationClass="com.esprito.spring.core.completion.properties.SpringPropertiesCompletionContributor"/>

        <completion.contributor language="yaml"
                                id="com.esprito.spring.core.yamlCompletionContributor"
                                implementationClass="com.esprito.spring.core.completion.yaml.SpringYamlCompletionContributor"/>

        <completion.contributor language="UAST"
                                order="first"
                                id="com.esprito.spring.core.properties.ConditionalOnConfigurationPrefixCompletionContributor"
                                implementationClass="com.esprito.spring.core.properties.ConditionalOnConfigurationPrefixCompletionContributor"/>

        <psi.referenceContributor language="Properties"
                                  implementation="com.esprito.spring.core.properties.SpringConfigurationPropertiesReferenceContributor"/>
        <psi.referenceContributor language="Properties"
                                  implementation="com.esprito.spring.core.autoconfigure.reference.AutoConfigureReferenceContributor"/>
        <psi.referenceContributor language="yaml"
                                  implementation="com.esprito.spring.core.completion.yaml.SpringYamlConfigurationPropertiesReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.core.properties.UastConfigurationPropertyReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.core.references.contributors.UastAliasMethodReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.core.references.contributors.UastMethodReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.core.references.contributors.UastBeanReferenceContributor"/>
        <psi.referenceContributor language="UAST"
                                  implementation="com.esprito.spring.core.references.contributors.QualifierReferenceContributor"/>
        <lang.documentationProvider language="Properties"
                                    order="first"
                                    implementationClass="com.esprito.spring.core.properties.SpringPropertiesDocumentationProvider"/>
        <lang.documentationProvider language="yaml"
                                    order="first"
                                    implementationClass="com.esprito.spring.core.completion.yaml.SpringYamlDocumentationProvider"/>

        <implicitUsageProvider implementation="com.esprito.spring.core.providers.SpringImplicitUsageProvider"/>
        <implicitUsageProvider implementation="com.esprito.spring.core.providers.SpringAopImplicitUsageProvider"/>
        <implicitUsageProvider implementation="com.esprito.spring.core.providers.SpringReferencedMethodUsageProvider"/>
        <implicitUsageProvider
                implementation="com.esprito.spring.core.providers.SpringConfigurationPropertyUsageProvider"/>

        <properties.implicitPropertyUsageProvider
                implementation="com.esprito.spring.core.providers.ConfigurationPropertyImplicitUsageProvider"/>
        <properties.implicitPropertyUsageProvider
                implementation="com.esprito.spring.core.autoconfigure.AutoConfigureImplicitPropertyUsageProvider"/>

        <lang.foldingBuilder
            language="UAST"
            implementationClass="com.esprito.spring.core.properties.ValueAnnotationFoldingBuilder"/>

        <languageInjectionContributor language="UAST"
                                      implementationClass="com.esprito.spring.core.language.injection.ConfigurationPropertiesInjector"/>

        <localInspection language="UAST"
                         shortName="SpringInjectionAutowiringInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.bean.autowired"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringBeanIncorrectAutowiringInspection"/>

        <localInspection language="UAST"
                         shortName="SpringEventListenerInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.method.eventListener"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringEventListenerInspection"/>

        <localInspection language="UAST"
                         shortName="SpringComponentScanInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.method.componentScan"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringComponentScanInvalidPackageInspection"/>

        <localInspection language="UAST"
                         shortName="SpringLookupBeanInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.bean.lookup"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringLookupBeanInspection"/>

        <localInspection language="UAST"
                         shortName="SpringDependsOnBeanInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.bean.dependsOn"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringDependsOnBeanInspection"/>

        <localInspection language="UAST"
                         shortName="SpringAliasBothInterchangeableSetInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.alias.interchangeable"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringAliasBothInterchangeableSetInspection"/>

        <localInspection language="UAST"
                         shortName="SpringUnknownAliasMethodInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.alias.attribute"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringUnknownAliasMethodInspection"/>

        <localInspection language="UAST"
                         shortName="SpringAliasNotMetaAnnotatedInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.alias.annotation"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringAliasNotMetaAnnotatedInspection"/>

        <localInspection language="UAST"
                         shortName="SpringUnknownBeanMethodInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.bean.method"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringUnknownBeanMethodInspection"/>

        <localInspection language="UAST"
                         shortName="SpringConfigurationProxyMethodsInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.configuration"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringConfigurationProxyMethodsInspection"/>

        <localInspection language="Properties"
                         shortName="SpringPropertiesInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="run.configuration.spring.boot.display.name"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.properties.key"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringPropertiesInspection"/>

        <localInspection language="Properties"
                         shortName="EnableAutoConfigureSpringFactoryInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="run.configuration.spring.boot.display.name"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.properties.key"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.esprito.spring.core.autoconfigure.inspection.EnableAutoConfigureSpringFactoryInspection"/>

        <localInspection language="UAST"
                         shortName="SpringConditionalOnEmptyValueInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.conditionalOnProperty.empty"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.esprito.spring.core.inspections.SpringConditionalOnEmptyValueInspection"/>

        <localInspection language="UAST"
                         shortName="SpringConditionalOnWrongPlacementInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.conditionalOn.wrongPlacement"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringConditionalOnWrongPlacementInspection"/>

        <localInspection language="UAST"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.property.source.file"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.PsiFileReferenceInspection"/>

        <localInspection language="UAST"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.property.source.classpath"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringPropertySourceClasspathInspection"/>
        <localInspection language="UAST"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.property.source.classpath"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringPropertySourceFileInspection"/>

        <localInspection language="UAST"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.context.configuration.classpath"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringContextConfigurationClasspathInspection"/>
        <localInspection language="UAST"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.context.configuration.classpath"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringContextConfigurationFileInspection"/>

        <localInspection language="UAST"
                         shortName="SpringProfileWrongPlacementInspection"
                         groupBundle="messages.SpringCoreBundle"
                         groupKey="esprito.spring.common.notifications"
                         bundle="messages.SpringCoreBundle"
                         key="esprito.spring.inspection.profile.wrongPlacement"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.esprito.spring.core.inspections.SpringProfileWrongPlacementInspection"/>

        <postStartupActivity
                implementation="com.esprito.spring.core.runconfiguration.SpringRunConfigurationDetectService$StartupActivity"/>

        <configurationType
                id="Spring Boot"
                implementation="com.esprito.spring.core.runconfiguration.SpringBootConfigurationType"/>

        <runConfigurationProducer
                order="first"
                implementation="com.esprito.spring.core.runconfiguration.SpringBootConfigurationProducer"/>

        <groupConfigurable id="com.esprito.spring.group"
                           parentId="tools"
                           displayNameKey="configurable.group.com.esprito.spring.group.settings.display.name"
                           descriptionKey="configurable.group.com.esprito.spring.group.settings.description"
                           bundle="messages.SpringCoreBundle"/>

        <applicationConfigurable id="com.esprito.spring.runConfigurations"
                                 key="run.configuration.spring.boot.display.name"
                                 groupId="com.esprito.spring.group"
                                 instance="com.esprito.spring.core.runconfiguration.SpringToolRunConfigurationConfigurable"
                                 groupWeight="85"/>

        <psi.referenceContributor
                implementation="com.esprito.spring.core.references.contributors.PackageAntReferenceInAnnotationContributor"
                language="UAST"/>
        <psi.referenceContributor
                implementation="com.esprito.spring.core.references.contributors.FileReferenceContributor"
                language="UAST"/>

        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.core.providers.SpringBeanLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.core.providers.EventListenerLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="UAST"
                                        implementationClass="com.esprito.spring.core.providers.ConfigurationPropertyLineMarkerProvider"/>

        <codeInsight.implicitSubclassProvider
                implementation="com.esprito.spring.core.providers.FinalDeclarationImplicitSubclassProvider"/>

        <fileType name="spring.factories"
                  fieldName="INSTANCE"
                  implementationClass="com.esprito.spring.core.autoconfigure.language.FactoriesFileType"/>
        <fileType name="org.springframework.boot.autoconfigure.AutoConfiguration.imports"
                  fieldName="INSTANCE"
                  implementationClass="com.esprito.spring.core.autoconfigure.language.AutoConfigurationImportsFileType"/>

        <fileType name="Profiles File"
                  implementationClass="com.esprito.spring.core.language.profiles.ProfilesFileType"
                  fieldName="INSTANCE"
                  language="Profiles"/>

        <fileTemplateGroup implementation="com.esprito.spring.core.properties.FilePropertyTemplateGroupFactory"/>

        <lang.parserDefinition
                language="Profiles"
                implementationClass="com.esprito.spring.core.language.profiles.ProfilesParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="Profiles"
                implementationClass="com.esprito.spring.core.language.profiles.ProfilesSyntaxHighlighterFactory"/>

        <multiHostInjector
                implementation="com.esprito.spring.core.language.profiles.injection.ProfilesToProfileAnnotationInjector"/>

        <completion.contributor
                language="Profiles"
                implementationClass="com.esprito.spring.core.language.profiles.ProfilesCompletionContributor"/>

        <psi.referenceContributor
                language="yaml"
                implementation="com.esprito.spring.core.language.profiles.YamlProfilesReferenceContributor"/>

        <psi.referenceContributor
                language="Properties"
                implementation="com.esprito.spring.core.language.profiles.PropertiesProfilesReferenceContributor"/>

        <psi.referenceContributor
                language="XML"
                implementation="com.esprito.spring.core.language.profiles.XmlProfilesReferenceContributor"/>

        <lang.braceMatcher
                language="Profiles"
                implementationClass="com.esprito.spring.core.language.profiles.psi.ProfilesBraceMatcher"/>

        <lang.inspectionSuppressor language="Properties"
                                   implementationClass="com.esprito.spring.core.autoconfigure.AutoConfigureImportsPropertiesInspectionSuppressor"/>
    </extensions>

    <actions>

    </actions>
</idea-plugin>